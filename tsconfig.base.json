{
  "compilerOptions": {
    "strict": true, "target": "ES2022", "module": "ESNext", "moduleResolution": "bundler",
    "types": ["bun-types"], "skipLibCheck": true, "noUncheckedIndexedAccess": true,
    "paths": { "@shared/*": ["packages/shared/src/*"], "@db/*": ["packages/db/src/*"],
               "@harness/*": ["packages/harness/src/*"], "@channels/*": ["packages/channels/src/*"] }
  }
}
