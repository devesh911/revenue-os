{
  "name": "revenue-os",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "bun": "1.3.11"
  },
  "scripts": {
    "dev": "bun run --filter services/worker dev & bun run --filter apps/console dev",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -b --noEmit || tsc --noEmit -p tsconfig.base.json",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "bun scripts/seed.ts",
    "rls:check": "psql \"$LOCAL_DB_URL\" -f tests/rls_coverage.sql",
    "evals": "bun scripts/evals.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/pg": "8.20.0",
    "bun-types": "1.3.14",
    "pg": "8.22.0",
    "typescript": "7.0.2"
  }
}
