{
  "name": "revenue-os",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "bun": "1.3.11"
  },
  "scripts": {
    "dev": "bun --watch services/worker/src/index.ts & bun run --filter console dev",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json && tsc --noEmit -p apps/console",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "bun scripts/seed.ts",
    "rls:check": "psql \"${LOCAL_DB_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres}\" -v ON_ERROR_STOP=1 -f tests/rls_coverage.sql",
    "gates": "bun run typecheck && bun run lint && bun test && bun run rls:check",
    "evals": "bun scripts/evals.ts",
    "guards": "bash scripts/guards.sh",
    "dev:console": "bun run --filter console dev",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/pg": "8.20.0",
    "bun-types": "1.3.11",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2"
  }
}
