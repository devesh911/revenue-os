{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "includes": ["**", "!orchestrator", "!.claude/worktrees"] },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 },
  "linter": { "enabled": true, "rules": { "preset": "recommended" } },
  "overrides": [
    {
      "includes": ["packages/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "bun": "G1: no Bun-only APIs in packages/* (tech-stack T1). Keep packages runtime-agnostic.",
                  "bun:test": "G1: import from vitest-compatible surface only in packages if ever needed; prefer app-level tests.",
                  "bun:sqlite": "G1",
                  "bun:ffi": "G1"
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/**/*.test.ts", "packages/**/test/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "bun": "G1: no Bun-only APIs in packages/* (tech-stack T1). Keep packages runtime-agnostic.",
                  "bun:sqlite": "G1",
                  "bun:ffi": "G1"
                }
              }
            }
          }
        }
      }
    }
  ]
}
